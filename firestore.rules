rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HOME SERV CONNECT SECURITY RULES
     * 
     * Update: Simplified read access for service requests to facilitate 
     * broad querying by customers and workers while maintaining signed-in 
     * requirements and ownership for writes.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Helper for update/delete to ensure document existence and ownership
    function isExistingOwner(ownerId) {
      return resource != null && request.auth.uid == ownerId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the UserProfile entity.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.firebaseUid == userId;
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Specialized collection for Database Access Control.
     * @path /roles_admin/{adminUid}
     */
    match /roles_admin/{adminUid} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Publicly readable catalog of services.
     * @path /service_categories/{serviceCategoryId}
     */
    match /service_categories/{serviceCategoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Subcollection detailing services provided by a specific worker.
     * @path /users/{workerId}/worker_services/{workerServiceId}
     */
    match /users/{workerId}/worker_services/{workerServiceId} {
      allow read: if isSignedIn();
      allow create: if isOwner(workerId) && request.resource.data.workerId == workerId;
      allow update: if isExistingOwner(workerId) && request.resource.data.workerId == resource.data.workerId;
      allow delete: if isExistingOwner(workerId);
    }

    /**
     * @description Collaborative resource for service requests.
     * @path /service_requests/{serviceRequestId}
     */
    match /service_requests/{serviceRequestId} {
      // Allow any signed-in user to list and get service requests.
      // Filtering is handled at the query level in the application code.
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.workerId == request.auth.uid || 
        isAdmin() ||
        (resource.data.status == 'PENDING' && request.resource.data.workerId == request.auth.uid) // Allow workers to accept
      );
      allow delete: if (resource != null && resource.data.customerId == request.auth.uid) || isAdmin();
    }

    /**
     * @description Collection for user reports.
     * @path /reports/{reportId}
     */
    match /reports/{reportId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}